# Handle line endings automatically for all files
* text=auto

# Force Unix line endings for source files
*.js    text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.rs    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.sh    text eol=lf

# Binary files — do not touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.exe   binary
*.msi   binary
*.wasm  binary
*.ttf   binary
*.woff  binary
*.woff2 binary
